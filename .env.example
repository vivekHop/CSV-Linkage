# ==========================================
# CSV Linkage - Workspace Configuration
# ==========================================

# --- Backend Configuration ---
PROJECT_NAME="CSV Linkage"
# For local dev, defaults to SQLite. For production/docker, set to PostgreSQL URL
DATABASE_URL="sqlite:///./csv_linkage.db"
SAMPLE_ROWS_LIMIT=5

# --- Search Configuration (Meilisearch, optional) ---
USE_MEILISEARCH=False
MEILISEARCH_URL="http://localhost:7700"
MEILISEARCH_KEY=""

# --- Frontend Configuration (Vite) ---
# Vite variables must be prefixed with VITE_ to be exposed to client code
VITE_API_URL="http://localhost:8000/api/v1"
VITE_WS_URL="ws://localhost:8000/ws"
